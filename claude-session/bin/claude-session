#!/usr/bin/env bash
set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$PATH"

REGISTRY_DIR="$HOME/.claude/active-sessions"

CURSOR_FILE="$REGISTRY_DIR/.cursor"

usage() {
    echo "Usage: claude-session sessions {list|get <id>|switch <id>|next|prev}" >&2
    exit 1
}

ai_title_for() {
    local cwd="$1" session_id="$2"
    local project_dir transcript
    project_dir=$(echo "$cwd" | tr '/' '-')
    transcript="$HOME/.claude/projects/${project_dir}/${session_id}.jsonl"
    if [[ -f "$transcript" ]]; then
        grep -o '"aiTitle":"[^"]*"' "$transcript" | tail -1 | sed 's/"aiTitle":"//;s/"$//' || true
    fi
}

sessions_list() {
    local files
    files=("$REGISTRY_DIR"/*.json)
    if [[ ! -e "${files[0]}" ]]; then
        echo "[]"
        return
    fi
    local result="[]"
    for f in "${files[@]}"; do
        local session cwd session_id title enriched
        session=$(cat "$f")
        cwd=$(echo "$session" | jq -r '.cwd')
        session_id=$(echo "$session" | jq -r '.session_id')
        title=$(ai_title_for "$cwd" "$session_id")
        enriched=$(echo "$session" | jq --arg t "$title" '. + {ai_title: $t}')
        result=$(echo "$result" | jq --argjson s "$enriched" '. + [$s]')
    done
    echo "$result"
}

sessions_get() {
    local id="${1:-}"
    [[ -n "$id" ]] || usage
    local file="$REGISTRY_DIR/${id}.json"
    if [[ ! -f "$file" ]]; then
        echo "error: session not found: $id" >&2
        exit 1
    fi
    cat "$file"
}

sorted_session_ids() {
    local files
    files=("$REGISTRY_DIR"/*.json)
    if [[ ! -e "${files[0]}" ]]; then return; fi
    jq -r '.claude_session_name + " " + .session_id' "${files[@]}" | sort | awk '{print $2}'
}

sessions_cycle() {
    local direction="$1"
    local ids=()
    while IFS= read -r id; do ids+=("$id"); done < <(sorted_session_ids)
    [[ ${#ids[@]} -eq 0 ]] && return

    local cursor="" current_index=-1
    [[ -f "$CURSOR_FILE" ]] && cursor=$(cat "$CURSOR_FILE")

    for i in "${!ids[@]}"; do
        if [[ "${ids[$i]}" == "$cursor" ]]; then
            current_index=$i
            break
        fi
    done

    local next_index=$(( (current_index + direction + ${#ids[@]}) % ${#ids[@]} ))
    local target="${ids[$next_index]}"
    echo "$target" > "$CURSOR_FILE"
    sessions_switch "$target"
}

sessions_switch() {
    local id="${1:-}"
    [[ -n "$id" ]] || usage
    local file="$REGISTRY_DIR/${id}.json"
    if [[ ! -f "$file" ]]; then
        echo "error: session not found: $id" >&2
        exit 1
    fi

    echo "$id" > "$CURSOR_FILE"

    local session zellij_session wezterm_tab_id zellij_pane_id
    session=$(cat "$file")
    zellij_session=$(echo "$session" | jq -r '.zellij_session')
    wezterm_tab_id=$(echo "$session" | jq -r '.wezterm_tab_id')
    zellij_pane_id=$(echo "$session" | jq -r '.zellij_pane_id')

    # Find live WezTerm socket
    local socket
    socket=$(ls "$HOME/.local/share/wezterm/gui-sock-"* 2>/dev/null | sort -t- -k3 -n | tail -1 || true)

    if [[ -n "${socket:-}" && "$wezterm_tab_id" != "null" ]]; then
        WEZTERM_UNIX_SOCKET="$socket" wezterm cli activate-tab --tab-id "$wezterm_tab_id"
    fi

    if [[ "$zellij_session" != "null" && "$zellij_pane_id" != "null" ]]; then
        zellij --session "$zellij_session" action focus-pane-id "$zellij_pane_id" || true
    fi
}

resource="${1:-}"
operation="${2:-}"
[[ -n "$resource" && -n "$operation" ]] || usage
shift 2

case "$resource/$operation" in
    sessions/list)   sessions_list "$@" ;;
    sessions/get)    sessions_get "$@" ;;
    sessions/switch) sessions_switch "$@" ;;
    sessions/next)   sessions_cycle 1 ;;
    sessions/prev)   sessions_cycle -1 ;;
    *)               usage ;;
esac
